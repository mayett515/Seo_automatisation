{
  "name": "local-seo-platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "corepack pnpm -r --if-present --workspace-concurrency=1 run build",
    "dev": "corepack pnpm -r --parallel --if-present run dev",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "text:check": "tsx tools/check-text-health.ts && tsx tools/check-architecture-regression-guards.ts",
    "typecheck": "tsc -p tools/tsconfig.json --noEmit && corepack pnpm -r --if-present --workspace-concurrency=1 run typecheck",
    "test": "tsx --test \"tools/**/*.test.ts\" && corepack pnpm -r --if-present --workspace-concurrency=1 run test",
    "test:browser": "playwright test",
    "test:integration": "corepack pnpm -r --if-present --workspace-concurrency=1 run test:integration",
    "db:check": "corepack pnpm --filter @localseo/db db:check",
    "check": "corepack pnpm format:check && corepack pnpm text:check && git diff --check && corepack pnpm lint && corepack pnpm typecheck && corepack pnpm db:check && corepack pnpm build && corepack pnpm test",
    "turbo:build": "turbo run build",
    "turbo:typecheck": "turbo run typecheck",
    "db:generate": "corepack pnpm --filter @localseo/db db:generate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tanstack/eslint-plugin-query": "^5.101.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.4",
    "tsx": "4.22.4",
    "turbo": "2.10.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
