NODE_ENV=development
# Local scaffold auth allows demo-project and x-user-id helpers for local development only.
# Never enable it for production or real-data preview environments.
ALLOW_LOCAL_SCAFFOLD_AUTH=true
VITE_LOCAL_SCAFFOLD_AUTH=true
PORT=4000
WEB_ORIGIN=http://localhost:5173
API_PUBLIC_URL=http://localhost:4000
# Use a hop count such as 1 behind one trusted production load balancer. Do not use true in production.
TRUST_PROXY=false
DATABASE_URL=postgres://postgres:postgres@localhost:5432/local_seo
# Disposable database for integration tests. The integration harness resets its public schema.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/local_seo_test
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_SECONDS=30
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_PING_TIMEOUT_MS=2000
REDIS_URL=redis://localhost:6379
AWS_REGION=eu-central-1
S3_BUCKET=local-seo-artifacts
LOCAL_OBJECT_STORAGE_DIR=.local-object-storage
NETLIFY_AUTH_TOKEN=
AI_REASONING_PROVIDER=mock
# Checked-in example keeps GLM for page/content/frontend experiments.
# The first real opportunity-scout smoke should override this in an external env file:
# AI_REASONING_MODEL=deepseek-v4-flash
# Future search/SERP/competitor workers should use task-specific DeepSeek config.
AI_REASONING_MODEL=glm-5.2
AI_REASONING_OPENCODE_GO_API_KEY=
AI_REASONING_OPENCODE_GO_ENDPOINT=https://opencode.ai/zen/go/v1/chat/completions
AI_REASONING_TIMEOUT_MS=120000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/gsc/callback
GSC_TOKEN_ENCRYPTION_KEY=replace-with-at-least-32-characters
GSC_OAUTH_STATE_SECRET=replace-with-at-least-32-characters
# Generate production secrets with a random source, for example: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:4000
